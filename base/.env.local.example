# MongoDB Connection
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=Cluster0
MONGODB_DB=wellbeing_app

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Local app URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_FITNESS_URL=http://localhost:3005
NEXT_PUBLIC_NUTRITION_URL=http://localhost:3003
NEXT_PUBLIC_RESTAURANTS_URL=http://localhost:3004
NEXT_PUBLIC_SKIN_URL=http://localhost:3002
NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3006

# Optional integrations
NEXT_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_public_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_SPEC_MODEL=gpt-4o-mini
NEXT_PUBLIC_CLOUD_STORAGE_URL=https://api.storage.example.com

# Legacy auth config still present in some local setups
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
