# Mongo Connection
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Shared Service URLs (Cloud Run URLs)
NEXT_PUBLIC_BASE_URL=https://base-xxx.a.run.app
NEXT_PUBLIC_FITNESS_URL=https://fitness-xxx.a.run.app
NEXT_PUBLIC_NUTRITION_URL=https://nutrition-xxx.a.run.app
NEXT_PUBLIC_RESTAURANTS_URL=https://restaurants-xxx.a.run.app
NEXT_PUBLIC_SKIN_URL=https://skin-xxx.a.run.app
NEXT_PUBLIC_COMMUNITY_URL=https://community-xxx.a.run.app/community

# Optional: set COMMUNITY_DEV_DEMO=true for testing without a base app session
COMMUNITY_DEV_DEMO=false
