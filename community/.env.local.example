# Required for community posts, connections, agent chat, etc.
MONGODB_URI=mongodb+srv://...

# Optional (default wellbeing_app)
MONGODB_DB=wellbeing_app

# Must match base app JWT_SECRET (same cookie as localhost:3000 in dev)
JWT_SECRET=

# Optional: open Community without logging in on base (local only). Do NOT set in production.
# COMMUNITY_DEV_DEMO=true
# COMMUNITY_DEMO_USER_ID=demo-user
# COMMUNITY_DEMO_USER_NAME=Demo
# COMMUNITY_DEMO_EMAIL=demo@local.dev

# Agent chat / profile (Gemini)
GEMINI_API_KEY=

# Optional: link on sign-in page (default http://localhost:3000)
# NEXT_PUBLIC_BASE_APP_URL=http://localhost:3000

# Optional: URL shown in nav / other apps (default http://localhost:3000/community — base proxies to :3006)
# NEXT_PUBLIC_COMMUNITY_ENTRY_URL=http://localhost:3000/community
