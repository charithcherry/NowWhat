# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=Cluster0

# Optional (defaults to wellbeing_app)
MONGODB_DB=wellbeing_app

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Shared local app URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_FITNESS_URL=http://localhost:3005
NEXT_PUBLIC_NUTRITION_URL=http://localhost:3003
NEXT_PUBLIC_RESTAURANTS_URL=http://localhost:3004
NEXT_PUBLIC_SKIN_URL=http://localhost:3002
NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3006

# Optional base-path override if deployed behind a subpath
# NEXT_PUBLIC_BASE_PATH=

# Optional: open Community without logging in on base (local only). Do NOT set in production.
# COMMUNITY_DEV_DEMO=true
# COMMUNITY_DEMO_USER_ID=demo-user
# COMMUNITY_DEMO_USER_NAME=Demo
# COMMUNITY_DEMO_EMAIL=demo@local.dev

# Optional: URL shown in nav / other apps (default http://localhost:3000/community via base)
# NEXT_PUBLIC_COMMUNITY_ENTRY_URL=http://localhost:3000/community
