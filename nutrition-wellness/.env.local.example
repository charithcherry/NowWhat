# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=Cluster0
MONGODB_DB=wellbeing_app

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Shared local app URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_FITNESS_URL=http://localhost:3005
NEXT_PUBLIC_NUTRITION_URL=http://localhost:3003
NEXT_PUBLIC_RESTAURANTS_URL=http://localhost:3004
NEXT_PUBLIC_SKIN_URL=http://localhost:3002
NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3006

# Optional: allow mock authentic dish fallback in development only
ALLOW_MOCK_AUTHENTIC_DISH_FALLBACK=false

# Optional external dish retrieval/enrichment providers
ENABLE_WIKIDATA_AUTHENTIC_LOOKUP=true
ENABLE_DBPEDIA_AUTHENTIC_LOOKUP=true
ENABLE_USDA_AUTHENTIC_ENRICHMENT=true
ENABLE_OPENFOODFACTS_AUTHENTIC_ENRICHMENT=true
AUTHENTIC_LOOKUP_TIMEOUT_MS=4500
USDA_FOODDATA_API_KEY=DEMO_KEY

# Optional user for local testing
NEXT_PUBLIC_DEFAULT_USER_ID=demo-user

# Optional cron secret for /api/nutrition/insight-memory/finalize
NUTRITION_MEMORY_CRON_SECRET=replace_with_secret

# # Legacy auth config still present in some local setups
# JWT_SECRET=replace_with_a_long_random_secret
# JWT_EXPIRES_IN=7d
